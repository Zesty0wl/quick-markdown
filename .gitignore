# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# Xcode user-specific
xcuserdata/
*.xcuserstate
*.xcuserdatad/
*.xccheckout
*.moved-aside
*.xcscmblueprint

# Xcode build output
build/
DerivedData/
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# Generated by xcodegen
#
# We DO check the generated .xcodeproj into git so that contributors who
# don't have xcodegen installed can still open the project. Re-generate
# locally with `xcodegen generate` after editing `project.yml`.

# Swift Package Manager
.swiftpm/
.build/
Packages/
Package.pins
Package.resolved
# Keep the project-level resolved file so SPM dependency versions are
# locked across contributors.
!QuickMarkdown.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved

# Carthage / CocoaPods (unused, but ignored just in case)
Carthage/Build/
Pods/

# IDEs
.idea/
.vscode/

# fastlane (unused)
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# Logs / temp
*.log
*.tmp

# Release artifacts — uploaded to GitHub Releases, not tracked in git
*.pkg
*.pkg.sha256
*.dmg
*.dmg.sha256

